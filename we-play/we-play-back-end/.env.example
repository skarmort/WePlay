# Spring Boot Backend Environment Configuration
# Copy this file to .env in we-play-back-end/ directory

# Server Configuration
SERVER_PORT=8081
ENVIRONMENT=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/weplay
MONGODB_DATABASE=weplay

# PostgreSQL Configuration (Alternative to MongoDB)
# DB_URL=jdbc:postgresql://localhost:5432/weplay
# DB_USERNAME=your_username
# DB_PASSWORD=your_password
# DB_DRIVER=org.postgresql.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-1234567890abcdef
JWT_EXPIRATION=86400000

# Logging Configuration
LOGGING_LEVEL_COM_WEPLAY=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG
