# Django Backend Environment Configuration
# Copy this file to .env in we-play-front-end/weplayproject/ directory

# Django Core Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-12345678901234567890
ALLOWED_HOSTS=localhost,127.0.0.1,*.example.com
ENVIRONMENT=development

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=True
FRONTEND_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=weplay_users
DB_USER=postgres
DB_PASSWORD=akanabor
DB_HOST=localhost
DB_PORT=5432

