# WePlay Project - Environment Configuration Example
# Copy this file to .env in each service directory and update with your actual values

# ===== REACT FRONTEND (.env in we-play-front-end/) =====
REACT_APP_API_URL=http://localhost:8081/api
REACT_APP_ENVIRONMENT=development

# ===== SPRING BOOT BACKEND (.env in we-play-back-end/) =====
# Server Configuration
SERVER_PORT=8081
ENVIRONMENT=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/weplay
MONGODB_DATABASE=weplay

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT Configuration
JWT_SECRET=yourSuperSecretKeyChangeThisInProduction1234567890
JWT_EXPIRATION=86400000

# ===== DJANGO BACKEND (.env in we-play-front-end/weplayproject/) =====
# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-o02jlxm!79w_9s*4i17=2!srhs&tz!zzdo#96(m*x9_@b-fli1
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=True

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=weplay_users
DB_USER=postgres
DB_PASSWORD=akanabor
DB_HOST=localhost
DB_PORT=5432

# Frontend CORS
FRONTEND_URL=http://localhost:3000
